{
  "version": "2.0.0",
  "tasks": [
    {
      // "Magic" path: runs automatically when the folder is opened in VSCode.
      // The first time, VSCode asks to "Allow Automatic Tasks" — students click Allow once.
      // The script is idempotent: it creates .venv if missing and (re)installs deps.
      "label": "Setup Python environment",
      "type": "shell",
      "command": "bash",
      "args": ["setup.sh"],
      "windows": {
        "command": "powershell",
        "args": ["-ExecutionPolicy", "Bypass", "-File", "setup.ps1"]
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
